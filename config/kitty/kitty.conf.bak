# Font Configuration
font_size 12
adjust_line_height 5

# Window Configuration
window_padding_width 0 8
window_padding_height 10
dynamic_background_opacity yes
background_opacity 0.95
hide_window_decorations yes

# Cursor Configuration
cursor_shape block
cursor_blink_interval 1

# window-padding-x

# Scrollback
scrollback_lines 3000

# Terminal features
copy_on_select yes
strip_trailing_spaces smart

# Key bindings for common actions
map ctrl+shift+n new_window
map ctrl+shift+t new_tab
map ctrl+plus change_font_size all +0.5
map ctrl+minus change_font_size all -0.5
map ctrl+0 change_font_size all 0

map ctrl+shift+a set_background_opacity +0.1
map ctrl+shift+b set_background_opacity -0.1

# Tab configuration
tab_bar_style powerline
tab_bar_align left
tab_bar_edge top

# Shell integration
shell_integration enabled
# BEGIN_KITTY_THEME
# Noctalia
include current-theme.conf
# END_KITTY_THEME


# BEGIN_KITTY_FONTS
font_family      family='Iosevka Nerd Font Mono' style=SemiBold
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS
